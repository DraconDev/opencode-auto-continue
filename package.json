{
  "name": "@dracondev/opencode-auto-continue",
  "version": "7.21.0",
  "description": "Auto-continue stalled OpenCode sessions \u2014 stall recovery, todo nudging, review on completion, and AI-driven session analysis",
  "keywords": [
    "opencode",
    "opencode-plugin",
    "stall-recovery",
    "session-recovery",
    "auto-recovery",
    "stuck-session",
    "abort",
    "continue"
  ],
  "license": "AGPL-3.0-only",
  "author": "dracon",
  "homepage": "https://github.com/DraconDev/opencode-auto-continue",
  "repository": {
    "type": "git",
    "url": "https://github.com/DraconDev/opencode-auto-continue"
  },
  "bugs": {
    "url": "https://github.com/DraconDev/opencode-auto-continue/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.0.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.4.10",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.9"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --max-warnings=0",
    "format": "prettier --write \"src/**/*.ts\" \"scripts/**/*.js\" \"*.md\"",
    "sync": "npm run build && node scripts/sync.js",
    "prepublishOnly": "npm run build"
  }
}