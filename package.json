{
  "name": "opencode-auto-continue",
  "version": "7.8.29",
  "description": "Auto-continue stalled OpenCode sessions — stall recovery, todo nudging, review on completion, and AI-driven session analysis",
  "keywords": [
    "opencode",
    "opencode-plugin",
    "stall-recovery",
    "session-recovery",
    "auto-recovery",
    "stuck-session",
    "abort",
    "continue"
  ],
  "license": "MIT",
  "author": "dracon",
  "homepage": "https://github.com/DraconDev/opencode-auto-continue",
  "repository": {
    "type": "git",
    "url": "https://github.com/DraconDev/opencode-auto-continue"
  },
  "bugs": {
    "url": "https://github.com/DraconDev/opencode-auto-continue/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@tarquinen/opencode-dcp": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "@tarquinen/opencode-dcp": ">=3.0.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.4.10",
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.9"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "sync": "npm run build && cp src/index.ts ~/.config/opencode/plugins/opencode-auto-continue/index.ts && cp dist/index.js ~/.config/opencode/plugins/opencode-auto-continue/index.js && cp dist/index.d.ts ~/.config/opencode/plugins/opencode-auto-continue/index.d.ts",
    "prepublishOnly": "npm run build"
  }
}
