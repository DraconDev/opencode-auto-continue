{
  "name": "opencode-auto-force-resume",
  "version": "3.6.8",
  "description": "OpenCode plugin that automatically detects stalled sessions and recovers via abort+continue",
  "keywords": [
    "opencode",
    "opencode-plugin",
    "stall-recovery"
  ],
  "license": "MIT",
  "author": "dracon",
  "homepage": "https://github.com/DraconDev/opencode-auto-force-resume",
  "repository": {
    "type": "git",
    "url": "https://github.com/DraconDev/opencode-auto-force-resume"
  },
  "bugs": {
    "url": "https://github.com/DraconDev/opencode-auto-force-resume/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.0.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.4.10",
